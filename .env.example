# Copy this file to .env on the deployment host and supply values from a secret manager.
STACK_NAME=qls-main
ASPNETCORE_ENVIRONMENT=Production
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=5078
POSTGRES_PORT=5432
POSTGRES_BIND_IP=127.0.0.1
REVERSE_PROXY_IP=172.17.0.1
BACKEND_IMAGE=your-registry/qls-backend:tag

DB_NAME=QLS_PROD
DB_USER=qls_user
DB_PASSWORD=replace-with-a-long-random-password
JWT_KEY=replace-with-a-long-random-jwt-signing-key
LG_API_KEY=replace-with-the-rotated-lg-api-key
ZALO_APP_ID=replace-with-your-zalo-app-id
ZALO_APP_SECRET_KEY=replace-with-the-rotated-zalo-secret

CORS_ORIGIN_0=https://admin.qlaundrystation.com
CORS_ORIGIN_1=https://dev.qlaundrystation.com
CORS_ORIGIN_2=https://qls-web.vercel.app
CORS_ORIGIN_3=https://h5.zdn.vn
CORS_ORIGIN_4=https://h5.zadn.vn

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
LOYALTY_MINI_APP_CLAIM_URL_TEMPLATE=https://zalo.me/s/miniapp?claimToken={token}
