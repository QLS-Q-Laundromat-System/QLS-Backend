# QLS Backend - Environment Variables
# This file is an example only. Copy to .env on each server.

# Deployment profile
STACK_NAME=qls-main
ASPNETCORE_ENVIRONMENT=Production
BACKEND_PORT=5078
POSTGRES_PORT=5432
POSTGRES_BIND_IP=127.0.0.1
BACKEND_IMAGE=your-dockerhub-username/your-image-name:latest

# Database
DB_NAME=QLS_PROD
DB_USER=qls_user
DB_PASSWORD=QLS12345

# JWT Secret
JWT_KEY=change-this-long-random-jwt-secret

# CORS
CORS_ORIGIN_0=http://localhost:5173
CORS_ORIGIN_1=https://admin.qlaundrystation.com
CORS_ORIGIN_2=https://dev.qlaundrystation.com
CORS_ORIGIN_3=https://qls-web.vercel.app
CORS_ORIGIN_4=https://h5.zdn.vn
CORS_ORIGIN_5=https://h5.zadn.vn

# Zalo Mini App
ZALO_APP_ID=572235974883145642
ZALO_APP_SECRET_KEY=replace-with-rotated-secret-on-server
LOYALTY_MINI_APP_CLAIM_URL_TEMPLATE=https://zalo.me/s/572235974883145642?claimToken={token}

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
